# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Used for conversation title generation (gpt-4o-mini) AND for RAG embeddings
# (text-embedding-3-small, see EMBEDDINGS_MODEL below). The chat/explanation
# pipeline itself uses Anthropic, but this key is effectively required for any
# RAG / knowledge-repo feature, not just titles.
OPENAI_API_KEY=your-openai-api-key-here
# Optional override of the title model (default: gpt-4o-mini).
# OPENAI_TITLE_MODEL=gpt-4o-mini

# ─── Database ────────────────────────────────────────────────────────────────
# SQLAlchemy async DSN. Holds users, projects, conversations, messages,
# analytics, and the KB registry (knowledge_bases, kb_documents, kb_chunks,
# kb_repos). Leave unset to use a local SQLite file (data/rule_agent.db) for dev.
# Postgres example (production):
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/rule_agent
# The synchronous DSN (used by the sync token-usage writer and the migration
# scripts) is derived automatically (+asyncpg→+psycopg, aiosqlite→sqlite);
# override only if needed:
#   DATABASE_URL_SYNC=postgresql+psycopg://user:pass@localhost:5432/rule_agent
DATABASE_URL=

# Optional per-tier model overrides (defaults shown). Models are chosen per task:
#   FAST     — routing / intent classification / follow-up suggestions / persona selector
#   STANDARD — rule explanations, analyst answers, PM persona stories
#   DEEP     — Engineer persona file-edit generation
# Each is read live, so you can flip a tier (e.g. DEEP between Opus and Sonnet)
# by changing the value and restarting — no code change needed.
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_STANDARD=claude-sonnet-4-6
ANTHROPIC_MODEL_DEEP=claude-opus-4-8

# ─── Knowledge bases / RAG ──────────────────────────────────────────────────────
# Directory of KB descriptor YAML files (backend/kb/<id>.yaml).
# KB_DIR=backend/kb

# Default knowledge base id, served when no KB is explicitly selected or when
# ENABLE_KB_SWITCHER=false. Must match a descriptor id in KB_DIR.
ACTIVE_KB=customer_sap

# Set to "false" to pin the app to ACTIVE_KB only, ignoring any
# client-requested knowledge_base_id (disables the in-app KB switcher).
ENABLE_KB_SWITCHER=true

# OpenAI embeddings model used for RAG ingestion (python -m ingest) and query
# embedding at chat time. Requires OPENAI_API_KEY.
EMBEDDINGS_MODEL=text-embedding-3-small

# Secret used to derive the Fernet key that encrypts a self-service Git-repo
# KB's private-repo access token at rest (kb_repos.auth_token_encrypted).
# Leave unset and tokens are stored in PLAINTEXT (a one-time warning is
# logged, never the token itself) — fine for local dev, set this in production
# before letting users add private repos via Settings > Knowledge repositories.
KB_REPO_SECRET_KEY=

# ─── Authentication ────────────────────────────────────────────────────────────
# Bearer token required for all protected endpoints (/chat, /kbs, /kb/*,
# /kb-repos*, /feedback, /users/login, /projects*, /conversations*).
# Leave empty to run with no authentication (local dev only).
# Generate a strong token: python -c "import secrets; print(secrets.token_urlsafe(32))"
RULE_AGENT_API_TOKEN=

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "production" to enforce auth token at startup (startup fails if token missing).
# Leave as "development" for local dev.
RULE_AGENT_ENV=development

# ─── Admin ───────────────────────────────────────────────────────────────────
# Username/password checked by POST /admin/login (returns a session token for
# the admin dashboard). In dev mode with no password set, any credentials are
# accepted. RULE_AGENT_ADMIN_TOKEN is the Bearer token required by /admin/*
# endpoints (e.g. POST /admin/reload); falls back to RULE_AGENT_API_TOKEN if unset.
RULE_AGENT_ADMIN_USER=admin
RULE_AGENT_ADMIN_PASSWORD=
RULE_AGENT_ADMIN_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Defaults to localhost:5173 if not set.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Rate limiting ─────────────────────────────────────────────────────────────
# Max /chat requests per minute per IP.
CHAT_RATE_LIMIT=30

# ─── Message limits ───────────────────────────────────────────────────────────
MAX_MESSAGE_LENGTH=2000
# Max length for Data Engineer / Project Manager mode messages (pasted user
# stories are longer than analyst questions).
MAX_PERSONA_MESSAGE_LENGTH=12000

# ─── LLM cost estimate (optional) ─────────────────────────────────────────────
# USD per 1 million tokens for your Anthropic usage. When BOTH are set, the admin
# dashboard shows an estimated spend figure on the Tokens Used card. Leave empty
# to hide the cost estimate. Rates depend on the model tier — check Anthropic
# pricing (note: tiered models mix Haiku/Sonnet/Opus rates, so this is a rough
# blended estimate).
RULE_AGENT_PROMPT_COST_PER_1M=
RULE_AGENT_COMPLETION_COST_PER_1M=

# ─── Nominatim geocoding (optional — only needed if using geolocator_search) ──
# Hostname:port of the internal Nominatim geocoding service. No default.
# If unset, geocoding calls return a config_error status and no coordinates.
NOMINATIM_DOMAIN=

# Set to "false" only on trusted internal networks with a controlled CA.
# Default: true (TLS verification enabled).
NOMINATIM_VERIFY_TLS=true

# Path to a custom CA bundle (PEM) for corporate PKI.
# Also respects the standard REQUESTS_CA_BUNDLE environment variable.
NOMINATIM_CA_BUNDLE=
