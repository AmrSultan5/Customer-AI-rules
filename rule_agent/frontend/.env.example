# Copy to .env and fill in values for your deployment.
# NEVER commit .env to version control.

# Backend origin for cross-origin production deployments.
# Leave empty when frontend and backend share the same domain (e.g. behind nginx).
VITE_API_BASE_URL=

# API bearer token.
# ⚠️  SECURITY: This value is embedded in the browser bundle at build time.
#     Only use behind internal access controls (VPN, SSO, corporate network).
#     Never deploy this on a public internet-facing site.
VITE_API_TOKEN=
